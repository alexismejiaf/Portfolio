# Canonical public site URL. Used by metadataBase, OpenGraph, sitemap, robots,
# and JSON-LD. Falls back to Vercel's auto-injected VERCEL_PROJECT_PRODUCTION_URL
# / VERCEL_URL when deployed, then http://localhost:3000 in local dev.
#
# Set this in Vercel project env vars for production (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://portfolio-alexis-mejia.vercel.app
