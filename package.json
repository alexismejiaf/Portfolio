{
  "name": "bryan-portfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.json && tsc --noEmit -p e2e/tsconfig.json",
    "type-check:app": "tsc --noEmit",
    "type-check:scripts": "tsc --noEmit -p scripts/tsconfig.json",
    "type-check:e2e": "tsc --noEmit -p e2e/tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lhci": "lhci autorun",
    "optimize:images": "bun run scripts/optimize-images.ts",
    "audit": "bun audit",
    "remotion:render": "remotion render LiquidGlassHero public/hero-loop.mp4 --codec=h264 && remotion render LiquidGlassHero public/hero-loop.webm --codec=vp9 && remotion still LiquidGlassHero public/hero-poster.jpg --frame=75",
    "prepare": "husky"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "motion": "^12.42.2",
    "next": "^16.2.11",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "remotion": "^4.0.498"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@remotion/bundler": "^4.0.498",
    "@remotion/cli": "^4.0.498",
    "@remotion/renderer": "^4.0.498",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.11",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.2.0",
    "prettier": "^3.9.6",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "body-parser": "^1.20.6",
    "brace-expansion": "^1.1.16",
    "fast-uri": "^3.1.4",
    "postcss": "^8.5.10",
    "sharp": "^0.35.3",
    "tmp": "^0.2.7",
    "uuid": "^11.1.1"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
